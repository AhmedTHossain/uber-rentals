# ---------- Database ----------
# Local dev: direct connection. Production (Supabase): set this to the POOLED
# (transaction, :6543) URL and DB_POOLED=true; set DIRECT_URL to the :5432 URL.
DATABASE_URL="postgres://postgres:postgres@localhost:5433/uber_rentals"
# DIRECT_URL=""                  # direct (non-pooled) URL — used for migrations
DB_POOLED="false"                # "true" behind a transaction pooler (disables prepared statements)
# DB_POOL_MAX="1"                # per-instance pool size (serverless: keep small)

# ---------- Auth (Auth.js / NextAuth v5) ----------
AUTH_SECRET="generate-a-strong-random-secret"   # `openssl rand -base64 32`
AUTH_TRUST_HOST="true"
# AUTH_URL="https://your-domain.com"             # set in production

# ---------- Scheduled jobs ----------
CRON_SECRET="generate-a-strong-random-secret"
APP_URL="http://localhost:3000"                  # used by `npm run cron`
CRON_SCHEDULE="0 6 * * *"

# ---------- Storage ----------
STORAGE_DRIVER="local"           # "local" (dev) | "r2" (production)
STORAGE_DIR="./public/uploads"
STORAGE_PUBLIC_PREFIX="/uploads"
# --- Cloudflare R2 (when STORAGE_DRIVER=r2) ---
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET=""
# R2_PUBLIC_BASE="https://<bucket>.<account>.r2.dev"

# ---------- Observability (optional) ----------
# Set a DSN to route errors to Sentry (see src/lib/observability.ts).
# NEXT_PUBLIC_SENTRY_DSN=""

# ---------- Demo ----------
# Pins "today" so seeded demo data stays coherent. OMIT in production.
NEXT_PUBLIC_DEMO_TODAY="2026-05-30"
